{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"module": "commonjs",
		"types": ["jest", "node"],
		"resolveJsonModule": true,
		"moduleResolution": "node",
		"esModuleInterop": true,
		"isolatedModules": true
	},
	"include": ["jest.config.ts", "src/**/*.ts"]
}
