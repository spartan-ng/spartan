{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"module": "preserve",
		"target": "es2016",
		"types": ["vitest/globals", "node"],
		"moduleResolution": "bundler",
		"isolatedModules": true
