{
	"name": "registry",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "libs/registry/src",
	"projectType": "library",
	"tags": [],
	"targets": {
		"build": {
			"executor": "@nx/js:tsc",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/libs/registry",
				"main": "libs/registry/src/index.ts",
				"tsConfig": "libs/registry/tsconfig.lib.json",
				"assets": ["libs/registry/*.md"]
			}
		},
		"test": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"configFile": "libs/registry/vite.config.mts"
			}
		}
	}
}
