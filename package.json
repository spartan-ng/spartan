{
	"name": "spartan",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "NODE_OPTIONS=--max-old-space-size=6000 nx run-many --target build --all --parallel=1",
		"build-storybook": "nx build-storybook ui-storybook",
		"changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
		"dev": "nx serve app",
		"drizzle": "npx drizzle-kit generate --config=./apps/app/drizzle.config.ts",
		"e2e": "nx run-many --target e2e --projects=tag:scope:e2e --all --parallel=1 --outputStyle=stream",
		"format": "nx format --write --all",
		"generate-snippets": "npx nx generate @spartan-ng/tools:generate-primitive-snippets",
		"lint": "nx run-many --target=lint --parallel",
		"pre-manual-release": "pnpm run prepare-manual-release && pnpm run format && nx run tools:lint --fix",
		"prepare-manual-release": "nx g @spartan-ng/tools:set-release-version && nx run-many --target=lint --parallel --fix && nx g @spartan-ng/tools:hlm-to-cli-generator",
		"release": "pnpm run release-ui && pnpm run release-cli && pnpm run release-mcp",
		"release-cli": "nx run-many --target=release --projects=tag:scope:cli --parallel=1",
		"release-mcp": "nx run-many --target=release --projects=tag:scope:mcp --parallel=1",
		"release-ui": "nx run-many --target=release --projects=tag:scope:brain --parallel=1",
		"smoke": "nx run cli-smoke:smoke",
		"start": "nx serve app",
		"storybook": "nx storybook ui-storybook",
		"test": "nx run-many --target test --all",
		"update-contributors": "nx generate @spartan-ng/tools:update-contributors",
		"update-hlm-component-preview": "nx generate @spartan-ng/tools:generate-hlm-component-preview",
		"update-ui-docs-snapshot": "nx run tools:generate-ui-docs && nx test tools --skip-nx-cache -- --update"
	},
